{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "jsx": "react-jsx",
    "moduleResolution": "Node",
    "types": ["vite/client"],
    "strict": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "baseUrl": "src",
    "paths": {
      "@/*": ["*"],
      "@app/*": ["app/*"],
      "@cardSectionToolbar/*": ["features/cardSectionToolbar/*"],
      "@data/*": ["data/*"],
      "@db/*": ["db/*"],
      "@entities/*": ["entities/*"],
      "@features/*": ["features/*"],
      "@i18n/*": ["i18n/*"],
      "@middleware/*": ["middleware/*"],
      "@schemas/*": ["schemas/*"],
      "@shared/*": ["shared/*"],
      "@styles/*": ["styles/*"],
      "@cardPanel/*": ["features/cardPanel/*"],
      "@cardphoto/*": ["features/cardphoto/*"],
      "@cardtext/*": ["features/cardtext/*"],
      "@envelope/*": ["features/envelope/*"],
      "@aroma/*": ["features/aroma/*"],
      "@date/*": ["features/date/*"],
      "@toolbar": ["features/toolbar/index.ts"],
      "@toolbar/*": ["features/toolbar/*"],
      "@cart/*": ["features/cart/*"],
      "@drafts/*": ["features/drafts/*"],
      "@sent/*": ["features/sent/*"],
      "@layout/*": ["features/layout/*"],
      "@layoutNav/*": ["features/layoutNav/*"]
    }
  },
  "include": ["src"]
}
