# Auth mode: "mock" (localStorage) or "http" (Laravel API)
VITE_AUTH_MODE=mock

# Leave empty — requests go to /api on the Vite dev server (same origin).
# VITE_API_BASE_URL=

# npm run dev on host (Docker backend on :8000) — default, no need to set:
# VITE_DEV_API_PROXY=http://127.0.0.1:8000
#
# Frontend inside Docker — set in docker-compose:
# VITE_DEV_API_PROXY=http://php:8000
