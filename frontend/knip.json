{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "project": ["src/**/*.{ts,tsx}", "scripts/**/*.{js,mjs,ts}"],
  "ignoreFiles": [
    "src/**/*.scss",
    "src/**/*.module.scss",
    "stats.html"
  ],
  "ignoreDependencies": [
    "@testing-library/jest-dom",
    "@testing-library/react",
    "@testing-library/user-event"
  ],
  "vite": {
    "config": "vite.config.ts"
  }
}
